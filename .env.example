# WxCC Callback Widget — Backend Environment Variables
# Copy this file to backend/.env and fill in your values.

# Port the backend listens on (default: 3000)
PORT=3000

# Hours before a callback record expires and is removed (default: 48)
CALLBACK_TTL_HOURS=48

# Optional: API key that WxCC Flow must include in X-Api-Key header
# when posting to /api/abandon.  Leave blank to allow unauthenticated posts.
ABANDON_API_KEY=

# Optional: API key for admin endpoints (clear-all, delete).
# Leave blank to allow unauthenticated admin access.
ADMIN_API_KEY=
