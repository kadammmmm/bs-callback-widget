{
  "_comment": "Navigation Page Layout for Abandoned Call Callback Widget",
  "_instructions": [
    "1. Export your current desktop layout from WxCC Admin Portal",
    "2. Find the 'navigation' array in your layout JSON",
    "3. Add this object to the navigation array",
    "4. Import the modified layout back to WxCC",
    "5. Assign to your teams",
    "6. REQUIRED: Set outdialEp and either outdialAni (single) or outdialAniList (multiple)"
  ],

  "_add_to_navigation_array": {
    "nav": {
      "label": "Callbacks",
      "icon": "call-log",
      "iconType": "momentum",
      "navigateTo": "callbacks",
      "align": "top"
    },
    "page": {
      "id": "callbacks",
      "widgets": {
        "callback-area": {
          "comp": "bs-callback-widget",
          "script": "https://kadammmmm.github.io/bs-callback-widget/index.js",
          "attributes": {
            "darkmode": "$STORE.app.darkMode"
          },
          "properties": {
            "backendUrl": "https://abandoncallbacks.bswxcc.com/api",
            "accessToken": "$STORE.auth.accessToken",
            "outdialEp": "$STORE.agent.outDialEp",
            "outdialAni": "+18005551234",
            "priorityWarningMins": 60,
            "priorityCriticalMins": 120
          }
        },
        "main-area": {
          "comp": "agentx-wc-interaction-control"
        }
      },
      "layout": {
        "areas": [["callback-area", "main-area"]],
        "size": {
          "cols": ["35%", "65%"],
          "rows": [1]
        }
      }
    }
  },

  "_property_reference": {
    "backendUrl": "Backend API URL",
    "accessToken": "Auth token from $STORE",
    "outdialEp": "Outdial Entry Point ID",
    "outdialAni": "Single Outdial ANI (caller ID)",
    "outdialAniList": "Multiple ANIs comma-separated (shows selector)",
    "priorityWarningMins": "Minutes before yellow warning indicator (default: 60)",
    "priorityCriticalMins": "Minutes before red critical indicator (default: 120)"
  },

  "_multi_ani_example": {
    "_comment": "Use this format if agents need to choose from multiple ANIs",
    "properties": {
      "backendUrl": "https://abandoncallbacks.bswxcc.com/api",
      "accessToken": "$STORE.auth.accessToken",
      "outdialEp": "$STORE.agent.outDialEp",
      "outdialAniList": "+18005551234,+18005555678,+18005559999",
      "priorityWarningMins": 30,
      "priorityCriticalMins": 60
    },
    "_note": "This example uses shorter priority thresholds (30min/60min)"
  },

  "_icon_options": [
    "call-log",
    "call-voicemail", 
    "callback",
    "handset",
    "phone-reply",
    "recents",
    "speed-dial"
  ]
}
