{
  "_comment": "Sample Desktop Layout JSON - Nav Panel Placement for Callback Widget",
  "_instructions": [
    "1. Export your current desktop layout from WxCC Admin Portal",
    "2. Find the 'panel' section with md-tabs",
    "3. Add a new tab and tab-panel for the callback widget",
    "4. Import the modified layout back to WxCC",
    "5. Assign to your teams"
  ],
  
  "nav_panel_widget": {
    "_description": "Add these two elements as children of the md-tabs component in your panel",
    "tab": {
      "comp": "md-tab",
      "attributes": {
        "slot": "tab",
        "aria-label": "Callbacks"
      },
      "children": [
        {
          "comp": "md-icon",
          "attributes": {
            "name": "icon-call-log_16"
          }
        },
        {
          "comp": "span",
          "textContent": "Callbacks"
        }
      ]
    },
    "tab_panel": {
      "comp": "md-tab-panel",
      "attributes": {
        "slot": "panel",
        "class": "widget-pane full-height"
      },
      "children": [
        {
          "comp": "bs-callback-widget",
          "script": "https://kadammmmm.github.io/bs-callback-widget/index.js",
          "properties": {
            "backendUrl": "https://bs-callback-backend.onrender.com/api"
          }
        }
      ]
    }
  },

  "_example_full_panel_section": {
    "area": {
      "panel": {
        "comp": "md-tabs",
        "attributes": {
          "class": "widget-tabs",
          "persist-selection": true,
          "tabs-id": "panel-tabs"
        },
        "children": [
          {
            "comp": "md-tab",
            "attributes": {
              "slot": "tab",
              "aria-label": "Contact History"
            },
            "children": [
              {
                "comp": "md-icon",
                "attributes": { "name": "icon-recents_16" }
              },
              {
                "comp": "span",
                "textContent": "Contact History"
              }
            ]
          },
          {
            "comp": "md-tab-panel",
            "attributes": {
              "slot": "panel",
              "class": "widget-pane"
            },
            "children": [
              {
                "comp": "agentx-contact-history"
              }
            ]
          },
          {
            "comp": "md-tab",
            "attributes": {
              "slot": "tab",
              "aria-label": "Callbacks"
            },
            "children": [
              {
                "comp": "md-icon",
                "attributes": { "name": "icon-call-log_16" }
              },
              {
                "comp": "span",
                "textContent": "Callbacks"
              }
            ]
          },
          {
            "comp": "md-tab-panel",
            "attributes": {
              "slot": "panel",
              "class": "widget-pane full-height"
            },
            "children": [
              {
                "comp": "bs-callback-widget",
                "script": "https://kadammmmm.github.io/bs-callback-widget/index.js",
                "properties": {
                  "backendUrl": "https://bs-callback-backend.onrender.com/api"
                }
              }
            ]
          }
        ]
      }
    }
  },

  "_css_recommendation": {
    "_comment": "Add this CSS to ensure full-height panel rendering",
    "style": ".widget-pane.full-height { height: 100%; display: flex; flex-direction: column; } .widget-pane.full-height bs-callback-widget { flex: 1; min-height: 0; }"
  }
}
